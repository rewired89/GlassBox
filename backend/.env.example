# ── GlassBox API — Environment Variables ────────────────────────────────────────
# Copy to .env and fill in values before running locally.
# On Railway: set these in the Variables panel.

# Required — get a FREE key at https://aistudio.google.com (no credit card needed)
GEMINI_API_KEY=AIza...

# Required — change this to a strong random string for your admin dashboard
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_KEY=change-me-to-something-random

# Optional — where to store data files
# On Railway: add a Volume mounted at /data and set DATA_DIR=/data
DATA_DIR=./data

# Optional — server port (Railway sets this automatically)
PORT=3001
