{
  "manifest_version": 3,
  "name": "GlassBox",
  "version": "2.1.0",
  "description": "AI-powered fact-checking and accountability — see the real context behind posts on any social media.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/dashboard.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "GlassBox"
  },
  "background": {
    "page": "background/background.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://twitter.com/*",
        "https://x.com/*",
        "https://www.reddit.com/*",
        "https://reddit.com/*",
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://www.tiktok.com/*",
        "https://tiktok.com/*"
      ],
      "js": ["content/glassbox.js"],
      "css": ["content/ui/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://www.reddit.com/*",
    "https://reddit.com/*",
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://www.tiktok.com/*",
    "https://tiktok.com/*",
    "https://glassbox-production-3db2.up.railway.app/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "glassbox@rewired89.com",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "content/ui/styles.css",
        "data/*.json",
        "icons/*.png"
      ],
      "matches": [
        "https://twitter.com/*",
        "https://x.com/*",
        "https://www.reddit.com/*",
        "https://reddit.com/*",
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://www.tiktok.com/*",
        "https://tiktok.com/*"
      ]
    }
  ]
}
